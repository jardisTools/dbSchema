{
    "name": "jardistools/dbschema",
    "homepage": "https://jardis.io",
    "description": "Database schema introspection and DDL export for MySQL, MariaDB, PostgreSQL, and SQLite",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "jardissupport/contracts": "^1.0",
        "jardissupport/dotenv": "^1.0",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "phpstan/phpstan": "2.2.3",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "JardisTools\\DbSchema\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisTools\\DbSchema\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisTools/dbSchema/issues",
        "docs": "https://docs.jardis.io/en/tools/dbschema",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "database",
        "pdo",
        "schema",
        "ddl",
        "database-introspection",
        "mysql",
        "postgres",
        "sqlite",
        "domain-driven-design",
        "php",
        "jardis",
        "headgent"
    ]
}
